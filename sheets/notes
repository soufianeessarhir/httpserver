// HttpServer.hpp
#ifndef HTTP_SERVER_HPP
#define HTTP_SERVER_HPP

#include <vector>
#include <map>
#include <string>
#include <sstream>
#include <stdexcept>
#include <sys/types.h>
#include <sys/socket.h>
#include <netdb.h>
#include <unistd.h>
#include <fcntl.h>
#include <sys/epoll.h>
#include <string.h>

// Forward declarations
class Server;
class HttpRequest;
class HttpResponse;

// Error class for HTTP server exceptions
class HttpServerError : public std::runtime_error {
public:
    HttpServerError(const std::string& message) : std::runtime_error(message) {}
};

// Client connection state
class ClientConnection {
public:
    enum State {
        READING_HEADERS,
        READING_BODY,
        PROCESSING,
        SENDING_RESPONSE,
        COMPLETE
    };

    int fd;
    State state;
    HttpRequest* request;
    HttpResponse* response;
    std::string buffer;
    size_t bytes_sent;
    time_t last_activity;

    ClientConnection(int client_fd);
    ~ClientConnection();
};

class HttpServer {
private:
    std::vector<Server>& servers;
    int epoll_fd;
    struct epoll_event ev;
    struct epoll_event events[MAX_EVENTS];
    std::map<int, Server> server_map;
    std::map<int, ClientConnection*> client_connections;
    
    // Initialize server sockets
    void init();
    
    // Set socket to non-blocking mode
    void setNonBlocking(int sockfd);
    
    // Handle new client connection
    void handleNewConnection(int server_fd);
    
    // Handle client data
    void handleClientData(int client_fd);
    
    // Handle client write readiness
    void handleClientWrite(int client_fd);
    
    // Process completed request
    void processRequest(ClientConnection* conn);
    
    // Check for timed out connections
    void checkTimeouts();
    
    // Clean up a client connection
    void cleanupClient(int fd);

public:
    HttpServer(std::vector<Server>& srvs);
    ~HttpServer();
    
    // Main server loop
    void run();
    
    // Clean up all resources
    void cleanup();
};

#endif

// HttpServer.cpp
#include "HttpServer.hpp"
#include "HttpRequest.hpp"
#include "HttpResponse.hpp"
#include "Server.hpp"

#define MAX_EVENTS 1024
#define TIMEOUT_SECONDS 60
#define MAX_REQUEST_SIZE 8192

ClientConnection::ClientConnection(int client_fd) : 
    fd(client_fd), 
    state(READING_HEADERS), 
    request(new HttpRequest()), 
    response(nullptr), 
    bytes_sent(0),
    last_activity(time(NULL)) {}

ClientConnection::~ClientConnection() {
    delete request;
    delete response;
}

HttpServer::HttpServer(std::vector<Server>& srvs) : servers(srvs) {
    epoll_fd = epoll_create1(0);
    if (epoll_fd == -1)
        throw HttpServerError("Epoll creation failed");
    this->init();
}

void HttpServer::init() {
    struct addrinfo hints, *res, *p;
    for (size_t i = 0; i < servers.size(); ++i) {
        for (size_t j = 0; j < servers[i].listen.size(); ++j) {
            memset(&hints, 0, sizeof(hints));
            hints.ai_family = AF_INET; // Could be AF_UNSPEC for both IPv4/IPv6
            hints.ai_socktype = SOCK_STREAM;
            hints.ai_flags = AI_PASSIVE;
            
            // Use NULL instead of "localhost" for binding to all interfaces
            std::string host = servers[i].listen[j].first.empty() ? 
                "" : servers[i].listen[j].first;
            std::ostringstream port;
            port << servers[i].listen[j].second;
            
            int ret = getaddrinfo(
                host.empty() ? NULL : host.c_str(), 
                port.str().c_str(),
                &hints, 
                &res
            );
            
            if (ret != 0) {
                throw HttpServerError("Getaddrinfo failed: " + std::string(gai_strerror(ret)));
            }
            
            int sockfd = -1;
            for (p = res; p != NULL; p = p->ai_next) {
                sockfd = socket(p->ai_family, p->ai_socktype, p->ai_protocol);
                if (sockfd == -1)
                    continue;
                
                // Set socket options
                int optval = 1;
                if (setsockopt(sockfd, SOL_SOCKET, SO_REUSEADDR, &optval, sizeof(optval)) == -1) {
                    close(sockfd);
                    continue;
                }
                
                // Set non-blocking
                setNonBlocking(sockfd);
                
                if (bind(sockfd, p->ai_addr, p->ai_addrlen) != -1)
                    break;
                
                close(sockfd);
                sockfd = -1;
            }
            
            freeaddrinfo(res);
            
            if (p == NULL)
                throw HttpServerError("Socket binding failed for " + 
                                     (host.empty() ? "*" : host) + ":" + port.str());
            
            if (listen(sockfd, SOMAXCONN) == -1) {
                close(sockfd);
                throw HttpServerError("Socket listening failed");
            }
            
            ev.events = EPOLLIN | EPOLLET;
            ev.data.fd = sockfd;
            if (epoll_ctl(epoll_fd, EPOLL_CTL_ADD, sockfd, &ev) == -1) {
                close(sockfd);
                throw HttpServerError("Epoll control failed");
            }
            
            server_map[sockfd] = servers[i];
        }
    }
}

void HttpServer::setNonBlocking(int sockfd) {
    int flags = fcntl(sockfd, F_GETFL, 0);
    if (flags == -1) {
        close(sockfd);
        throw HttpServerError("Failed to get socket flags");
    }
    if (fcntl(sockfd, F_SETFL, flags | O_NONBLOCK) == -1) {
        close(sockfd);
        throw HttpServerError("Failed to set socket non-blocking");
    }
}

void HttpServer::handleNewConnection(int server_fd) {
    while (true) { // Accept all pending connections
        struct sockaddr_storage client_addr;
        socklen_t client_len = sizeof(client_addr);
        
        int client_fd = accept(server_fd, (struct sockaddr*)&client_addr, &client_len);
        if (client_fd == -1) {
            if (errno == EAGAIN || errno == EWOULDBLOCK) {
                // No more connections to accept
                break;
            } else {
                // Real error
                throw HttpServerError("Accept failed");
            }
        }
        
        // Set non-blocking
        setNonBlocking(client_fd);
        
        // Create client connection object
        ClientConnection* conn = new ClientConnection(client_fd);
        client_connections[client_fd] = conn;
        
        // Add to epoll
        ev.events = EPOLLIN | EPOLLET;
        ev.data.fd = client_fd;
        if (epoll_ctl(epoll_fd, EPOLL_CTL_ADD, client_fd, &ev) == -1) {
            cleanupClient(client_fd);
            throw HttpServerError("Epoll control failed for client");
        }
    }
}

void HttpServer::handleClientData(int client_fd) {
    ClientConnection* conn = client_connections[client_fd];
    if (!conn) return;
    
    char buf[4096];
    ssize_t bytes_read;
    
    conn->last_activity = time(NULL);
    
    while ((bytes_read = read(client_fd, buf, sizeof(buf))) > 0) {
        conn->buffer.append(buf, bytes_read);
        
        // Check if buffer size exceeds maximum
        if (conn->buffer.size() > MAX_REQUEST_SIZE) {
            // Generate 413 Entity Too Large response
            conn->response = new HttpResponse(413);
            conn->state = ClientConnection::SENDING_RESPONSE;
            
            // Update epoll to wait for write readiness
            ev.events = EPOLLOUT | EPOLLET;
            ev.data.fd = client_fd;
            epoll_ctl(epoll_fd, EPOLL_CTL_MOD, client_fd, &ev);
            return;
        }
        
        // Process headers if we're still reading them
        if (conn->state == ClientConnection::READING_HEADERS) {
            size_t header_end = conn->buffer.find("\r\n\r\n");
            if (header_end != std::string::npos) {
                // Headers complete, parse them
                bool parse_result = conn->request->parseHeaders(conn->buffer.substr(0, header_end + 4));
                if (!parse_result) {
                    // Bad request
                    conn->response = new HttpResponse(400);
                    conn->state = ClientConnection::SENDING_RESPONSE;
                    
                    // Update epoll to wait for write readiness
                    ev.events = EPOLLOUT | EPOLLET;
                    ev.data.fd = client_fd;
                    epoll_ctl(epoll_fd, EPOLL_CTL_MOD, client_fd, &ev);
                    return;
                }
                
                // Remove headers from buffer
                conn->buffer.erase(0, header_end + 4);
                
                // Check if there's a body expected
                if (conn->request->expectsBody()) {
                    conn->state = ClientConnection::READING_BODY;
                } else {
                    conn->state = ClientConnection::PROCESSING;
                    processRequest(conn);
                    return;
                }
            }
        }
        
        // Process body if we're reading it
        if (conn->state == ClientConnection::READING_BODY) {
            size_t content_length = conn->request->getContentLength();
            
            // Check if we've received the complete body
            if (conn->buffer.size() >= content_length) {
                conn->request->setBody(conn->buffer.substr(0, content_length));
                conn->buffer.erase(0, content_length);
                
                conn->state = ClientConnection::PROCESSING;
                processRequest(conn);
                return;
            }
        }
    }
    
    if (bytes_read == 0) {
        // Client closed connection
        cleanupClient(client_fd);
        return;
    }
    
    if (bytes_read == -1) {
        if (errno == EAGAIN || errno == EWOULDBLOCK) {
            // No more data available right now
            return;
        } else {
            // Real error
            cleanupClient(client_fd);
            return;
        }
    }
}

void HttpServer::handleClientWrite(int client_fd) {
    ClientConnection* conn = client_connections[client_fd];
    if (!conn || conn->state != ClientConnection::SENDING_RESPONSE || !conn->response) {
        return;
    }
    
    conn->last_activity = time(NULL);
    
    const std::string& response_data = conn->response->getData();
    size_t remaining = response_data.size() - conn->bytes_sent;
    
    if (remaining > 0) {
        ssize_t bytes_sent = write(client_fd, 
                                 response_data.c_str() + conn->bytes_sent, 
                                 remaining);
        
        if (bytes_sent == -1) {
            if (errno == EAGAIN || errno == EWOULDBLOCK) {
                // Would block, try again later
                return;
            } else {
                // Real error
                cleanupClient(client_fd);
                return;
            }
        }
        
        conn->bytes_sent += bytes_sent;
        
        // Check if we've sent everything
        if (conn->bytes_sent >= response_data.size()) {
            // Complete, check if we should keep-alive
            if (conn->request->keepAlive()) {
                // Reset for next request
                delete conn->request;
                delete conn->response;
                conn->request = new HttpRequest();
                conn->response = nullptr;
                conn->state = ClientConnection::READING_HEADERS;
                conn->bytes_sent = 0;
                
                // Update epoll to wait for read readiness
                ev.events = EPOLLIN | EPOLLET;
                ev.data.fd = client_fd;
                epoll_ctl(epoll_fd, EPOLL_CTL_MOD, client_fd, &ev);
            } else {
                // Close connection
                cleanupClient(client_fd);
            }
        }
    }
}

void HttpServer::processRequest(ClientConnection* conn) {
    // Find the appropriate server config for this request
    const Server* server = nullptr;
    
    // First check based on Host header
    std::string host = conn->request->getHeader("Host");
    for (size_t i = 0; i < servers.size(); ++i) {
        for (size_t j = 0; j < servers[i].server_names.size(); ++j) {
            if (host == servers[i].server_names[j]) {
                server = &servers[i];
                break;
            }
        }
        if (server) break;
    }
    
    // If no match by hostname, use default server
    if (!server && !servers.empty()) {
        server = &servers[0];
    }
    
    // Generate response based on the request and server config
    conn->response = new HttpResponse(conn->request, server);
    conn->state = ClientConnection::SENDING_RESPONSE;
    
    // Update epoll to wait for write readiness
    ev.events = EPOLLOUT | EPOLLET;
    ev.data.fd = conn->fd;
    epoll_ctl(epoll_fd, EPOLL_CTL_MOD, conn->fd, &ev);
}

void HttpServer::checkTimeouts() {
    time_t current_time = time(NULL);
    std::vector<int> to_remove;
    
    for (std::map<int, ClientConnection*>::iterator it = client_connections.begin(); 
         it != client_connections.end(); ++it) {
        if (current_time - it->second->last_activity > TIMEOUT_SECONDS) {
            to_remove.push_back(it->first);
        }
    }
    
    for (size_t i = 0; i < to_remove.size(); ++i) {
        cleanupClient(to_remove[i]);
    }
}

void HttpServer::cleanupClient(int fd) {
    std::map<int, ClientConnection*>::iterator it = client_connections.find(fd);
    if (it != client_connections.end()) {
        // Remove from epoll
        epoll_ctl(epoll_fd, EPOLL_CTL_DEL, fd, NULL);
        
        // Close socket
        close(fd);
        
        // Delete connection object
        delete it->second;
        client_connections.erase(it);
    }
}

void HttpServer::run() {
    time_t last_timeout_check = time(NULL);
    
    while (true) {
        int event_count = epoll_wait(epoll_fd, events, MAX_EVENTS, 1000); // 1 second timeout
        
        if (event_count == -1) {
            if (errno == EINTR) {
                // Interrupted by signal, continue
                continue;
            }
            throw HttpServerError("Epoll wait failed");
        }
        
        for (int i = 0; i < event_count; ++i) {
            int current_fd = events[i].data.fd;
            
            // Check if this is a server socket
            if (server_map.find(current_fd) != server_map.end()) {
                // New connection
                handleNewConnection(current_fd);
            } else if (events[i].events & EPOLLIN) {
                // Data available to read
                handleClientData(current_fd);
            } else if (events[i].events & EPOLLOUT) {
                // Ready to write
                handleClientWrite(current_fd);
            }
            
            // Check for errors or hangups
            if (events[i].events & (EPOLLERR | EPOLLHUP)) {
                if (server_map.find(current_fd) == server_map.end()) {
                    cleanupClient(current_fd);
                }
            }
        }
        
        // Check for timeouts periodically
        time_t current_time = time(NULL);
        if (current_time - last_timeout_check > 5) { // Every 5 seconds
            checkTimeouts();
            last_timeout_check = current_time;
        }
    }
}

void HttpServer::cleanup() {
    // Clean up all client connections
    for (std::map<int, ClientConnection*>::iterator it = client_connections.begin(); 
         it != client_connections.end(); ++it) {
        close(it->first);
        delete it->second;
    }
    client_connections.clear();
    
    // Clean up all server sockets
    for (std::map<int, Server>::iterator it = server_map.begin(); 
         it != server_map.end(); ++it) {
        close(it->first);
    }
    server_map.clear();
}

HttpServer::~HttpServer() {
    if (epoll_fd != -1) {
        cleanup();
        close(epoll_fd);
    }
}

// HttpRequest.hpp (minimal implementation)
#ifndef HTTP_REQUEST_HPP
#define HTTP_REQUEST_HPP

#include <string>
#include <map>

class HttpRequest {
private:
    std::string method;
    std::string uri;
    std::string http_version;
    std::map<std::string, std::string> headers;
    std::string body;
    bool is_complete;

public:
    HttpRequest();
    ~HttpRequest();
    
    bool parseHeaders(const std::string& header_data);
    bool expectsBody() const;
    size_t getContentLength() const;
    void setBody(const std::string& body_data);
    std::string getHeader(const std::string& name) const;
    bool keepAlive() const;
    
    // Getters
    const std::string& getMethod() const { return method; }
    const std::string& getUri() const { return uri; }
    const std::string& getHttpVersion() const { return http_version; }
    const std::string& getBody() const { return body; }
};

#endif

// HttpResponse.hpp (minimal implementation)
#ifndef HTTP_RESPONSE_HPP
#define HTTP_RESPONSE_HPP

#include <string>
#include <map>

class HttpRequest;
class Server;

class HttpResponse {
private:
    int status_code;
    std::map<std::string, std::string> headers;
    std::string body;
    std::string response_data;
    
    void buildResponse();
    std::string getStatusText(int code);

public:
    HttpResponse(int code);
    HttpResponse(HttpRequest* request, const Server* server);
    ~HttpResponse();
    
    const std::string& getData() const { return response_data; }
};

#endif